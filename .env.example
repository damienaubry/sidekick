# Copy to .env.local and paste your keys. The app runs WITHOUT keys (seeded demo);
# adding both stores flips it to live HydraDB recall + Nebius synthesis.

# HydraDB — free "Ship" tier, no card: https://dashboard.hydradb.com/sign-up
HYDRA_DB_API_KEY=
HYDRA_DB_TENANT_ID=sidekick

# Nebius — you already have a key: studio.nebius.ai -> API Keys
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/
